  <Requirements:Requirement xmi:id="_Z5pFcFxiEfGmLbDHtKPTZw" base_NamedElement="_Z4f18FxiEfGmLbDHtKPTZw" id="REQ-00" text="The Smart Classroom shall provide air quality monitoring, automatic window control, occupancy information, prediction services, dashboard management, and sustainability support." base_Class="_Z4f18FxiEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_6tRTkFxiEfGmLbDHtKPTZw" base_NamedElement="_6tMbEFxiEfGmLbDHtKPTZw" id="REQ-01" text="The system shall monitor CO2, temperature, and humidity in the classroom every 10 minutes." base_Class="_6tMbEFxiEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_GX2rYFxjEfGmLbDHtKPTZw" base_NamedElement="_GX02MFxjEfGmLbDHtKPTZw" id="REQ-02" text="The system shall automatically open classroom windows when CO2 exceeds the defined threshold." base_Class="_GX02MFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_G9HUkFxjEfGmLbDHtKPTZw" base_NamedElement="_G9GGcFxjEfGmLbDHtKPTZw" id="REQ-03" text="The system shall provide real-time classroom occupancy based on people counter data." base_Class="_G9GGcFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_HEiyQFxjEfGmLbDHtKPTZw" base_NamedElement="_HEg9EFxjEfGmLbDHtKPTZw" id="REQ-04" text="The system shall predict classroom occupancy using historical occupancy data." base_Class="_HEg9EFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_HJzFsFxjEfGmLbDHtKPTZw" base_NamedElement="_HJx3kFxjEfGmLbDHtKPTZw" id="REQ-05" text="The system shall provide a ThingsBoard dashboard for the room administrator to monitor air quality, occupancy, alerts, and system status." base_Class="_HJx3kFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_uI-QEFxjEfGmLbDHtKPTZw" base_NamedElement="_uI9B8FxjEfGmLbDHtKPTZw" id="REQ-06" text="The student mobile application shall respond to occupancy requests in less than 2 seconds." base_Class="_uI9B8FxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_uQDIcFxjEfGmLbDHtKPTZw" base_NamedElement="_uQB6UFxjEfGmLbDHtKPTZw" id="REQ-07" text="The student mobile services shall provide at least 98% availability." base_Class="_uQB6UFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_uV-KQFxjEfGmLbDHtKPTZw" base_NamedElement="_uV8VEFxjEfGmLbDHtKPTZw" id="REQ-08" text="The system shall activate the window actuator within 10 minutes after a CO2 threshold breach is detected." base_Class="_uV8VEFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_ua1cIFxjEfGmLbDHtKPTZw" base_NamedElement="_ua01EFxjEfGmLbDHtKPTZw" id="REQ-09" text="Sensor and occupancy data shall be stored in the ThingsBoard database for 5 years." base_Class="_ua01EFxjEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_Q6qGUFxkEfGmLbDHtKPTZw" base_NamedElement="_Q6nqEFxkEfGmLbDHtKPTZw" id="REQ-10" text="The system shall support a healthy learning environment by maintaining CO2 concentration below the classroom threshold." base_Class="_Q6nqEFxkEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_RIJIsFxkEfGmLbDHtKPTZw" base_NamedElement="_RIHTgFxkEfGmLbDHtKPTZw" id="REQ-11" text="The system shall prioritize natural ventilation through window opening before using energy-intensive ventilation alternatives." base_Class="_RIHTgFxkEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_RlrZQFxkEfGmLbDHtKPTZw" base_NamedElement="_RlpkEFxkEfGmLbDHtKPTZw" id="REQ-12" text="The system shall reduce unnecessary energy consumption by opening windows only when air quality thresholds are exceeded." base_Class="_RlpkEFxkEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_RqRlYFxkEfGmLbDHtKPTZw" base_NamedElement="_RqQXQFxkEfGmLbDHtKPTZw" id="REQ-13" text="The system shall improve classroom space utilization by providing occupancy information and predictions to students." base_Class="_RqQXQFxkEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_Rtl_IFxkEfGmLbDHtKPTZw" base_NamedElement="_RtkxAFxkEfGmLbDHtKPTZw" id="REQ-14" text="The system shall provide sustainability metrics based on historical air quality and occupancy data." base_Class="_RtkxAFxkEfGmLbDHtKPTZw"/>
  <Requirements:Requirement xmi:id="_w4sTwFxlEfGmLbDHtKPTZw" base_NamedElement="_w4pQcFxlEfGmLbDHtKPTZw" base_Class="_w4pQcFxlEfGmLbDHtKPTZw"/>
